<Window x:Class="BankManagementSystem.ViewAccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Accounts"
        Height="650"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#14143C">

    <Grid Margin="10">

        <Border Background="White"
                CornerRadius="12"
                Padding="15">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TITLE -->

                <TextBlock Grid.Row="0"
                           Text="ALL ACCOUNT DETAILS"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->

                <DataGrid x:Name="dgAccounts"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          FontSize="12"
                          RowHeight="28"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F2F2F2"
                          Background="White"
                          BorderThickness="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                    <!-- HEADER STYLE -->

                    <DataGrid.ColumnHeaderStyle>

                        <Style TargetType="DataGridColumnHeader">

                            <Setter Property="Background"
                                    Value="#0078D7"/>

                            <Setter Property="Foreground"
                                    Value="White"/>

                            <Setter Property="FontWeight"
                                    Value="Bold"/>

                            <Setter Property="FontSize"
                                    Value="12"/>

                            <Setter Property="Height"
                                    Value="32"/>

                            <Setter Property="HorizontalContentAlignment"
                                    Value="Center"/>

                        </Style>

                    </DataGrid.ColumnHeaderStyle>

                    <!-- COLUMNS -->

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Acc No"
                                            Binding="{Binding AccountNumber}"
                                            Width="75"/>

                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding AccountType}"
                                            Width="90"/>

                        <DataGridTextColumn Header="First"
                                            Binding="{Binding FirstName}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Middle"
                                            Binding="{Binding MiddleName}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Last"
                                            Binding="{Binding LastName}"
                                            Width="90"/>

                        <DataGridTextColumn Header="DOB"
                                            Binding="{Binding DOB}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Gender"
                                            Binding="{Binding Gender}"
                                            Width="80"/>

                        <DataGridTextColumn Header="PAN"
                                            Binding="{Binding PanNumber}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Current Address"
                                            Binding="{Binding CurrentAddress}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Permanent Address"
                                            Binding="{Binding PermanentAddress}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Mobile"
                                            Binding="{Binding MobileNumber}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Balance"
                                            Binding="{Binding Balance}"
                                            Width="90"/>

                        <!-- DELETE BUTTON -->

                        <DataGridTemplateColumn Header="Delete"
                                                Width="100">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="Delete"
                                            Height="24"
                                            Width="70"
                                            Background="Red"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Tag="{Binding AccountNumber}"
                                            Click="BtnDelete_Click"/>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</Window>