<Window x:Class="BankManagementSystem.DepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deposit Amount"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1B1B3A">

    <Grid>

        <Border Width="350"
                Height="300"
                Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="DEPOSIT AMOUNT"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Account Number"/>
                <TextBox x:Name="txtAccountNumber"
                         Height="30"
                         Margin="0,5,0,15"/>

                <TextBlock Text="Amount"/>
                <TextBox x:Name="txtAmount"
                         Height="30"
                         Margin="0,5,0,20"/>

                <Button Content="Deposit"
                        Height="35"
                        Background="Green"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnDeposit_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>