<Window x:Class="BankManagementSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bank Login"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#14143C">

    <Grid>

        <Border Width="500"
                Height="430"
                Background="White"
                CornerRadius="12"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- TITLE -->

                <TextBlock Text="BANK LOGIN"
                           FontSize="38"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- USER ID -->

                <TextBlock Text="User ID"
                           FontSize="18"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="txtUserId"
                         Height="45"
                         FontSize="18"
                         Margin="0,0,0,25"/>

                <!-- PASSWORD -->

                <TextBlock Text="Password"
                           FontSize="18"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="txtPassword"
                             Height="45"
                             FontSize="18"
                             Margin="0,0,0,35"/>

                <!-- BUTTONS -->

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <!-- LOGIN BUTTON -->

                    <Button Content="Login"
                            Width="170"
                            Height="45"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#0078D7"
                            Foreground="White"
                            Margin="0,0,15,0"
                            Click="BtnLogin_Click"/>

                    <!-- CLEAR BUTTON -->

                    <Button Content="Clear"
                            Width="170"
                            Height="45"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="Gray"
                            Foreground="White"
                            Click="BtnClear_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</Window>